[Unit]
Description=AI vLLM HIP OpenAI Server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User={{ ai_engine_user }}
Group={{ ai_engine_group }}
WorkingDirectory={{ ai_engine_workspace }}
Environment=VLLM_USE_TRITON_FLASH_ATTN=0
ExecStart={{ ai_vllm_venv }}/bin/python -m vllm.entrypoints.openai.api_server --host 0.0.0.0 --port {{ ai_vllm_port }} --model {{ ai_vllm_model }}
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
